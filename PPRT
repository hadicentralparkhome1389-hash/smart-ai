<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gemine 1.2 - Pro</title>
    <style>
        /* Movement wali animation */
        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            font-family: 'Segoe UI', sans-serif;
            /* White/Grey moving background */
            background: linear-gradient(-45deg, #ffffff, #f0f0f0, #e0e0e0, #ffffff);
            background-size: 400% 400%;
            animation: gradientBG 10s ease infinite;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .main-card {
            width: 95%;
            height: 90vh;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            border: 1px solid #ddd;
        }

        header {
            padding: 20px;
            background: #ffffff;
            text-align: center;
            font-size: 28px;
            font-weight: 800;
            color: #333;
            border-bottom: 1px solid #eee;
            letter-spacing: 2px;
        }

        #chat-area {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .input-box {
            padding: 20px;
            display: flex;
            gap: 10px;
            background: #f9f9f9;
        }

        input {
            flex: 1;
            padding: 15px;
            border-radius: 30px;
            border: 1px solid #ccc;
            outline: none;
            font-size: 16px;
        }

        button {
            background: #333;
            color: white;
            border: none;
            padding: 0 25px;
            border-radius: 30px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #000;
            transform: scale(1.05);
        }
    </style>
</head>
<body>

    <div class="main-card">
        <header>GEMINE 1.2</header>
        
        <div id="chat-area">
            <div style="text-align: center; color: #999; margin-top: 20px;">
                System Ready. Movement Active.
            </div>
        </div>

        <div class="input-box">
            <input type="text" placeholder="Start typing...">
            <button>Send</button>
        </div>
    </div>

</body>
</html>
